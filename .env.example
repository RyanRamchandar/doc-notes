# OpenRouter note generation
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Preferred Deepgram setup for local/dev and Vercel:
# keep the long-lived key server-side and let /api/stt/token mint short-lived tokens.
DEEPGRAM_API_KEY=

# Optional browser-only fallback for quick local demos.
# Do not use this in production.
NEXT_PUBLIC_DEEPGRAM_API_KEY=

# Force demo transcription mode even if Deepgram credentials exist.
NEXT_PUBLIC_FORCE_MOCK=false
